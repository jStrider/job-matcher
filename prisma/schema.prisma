generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  profile   Profile?
  searches  Search[]
  jobs      SavedJob[]
  createdAt DateTime   @default(now())
}

model Profile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawText          String
  summary          String?
  currentTitle     String?
  yearsExperience  Int?
  skills           String[]
  languages        String[]
  education        String?
  location         String?
  desiredRoles     String[]
  desiredSalary    String?
  remotePreference String?
  updatedAt        DateTime @updatedAt
}

model Search {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  location  String?
  results   Job[]
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Job {
  id             String     @id @default(cuid())
  searchId       String
  search         Search     @relation(fields: [searchId], references: [id], onDelete: Cascade)
  title          String
  company        String
  location       String?
  salary         String?
  remote         String?
  contract       String?
  description    String
  url            String
  source         String
  atsScore       Int?
  scoreBreakdown Json?
  missingSkills  String[]
  matchingSkills String[]
  savedJobs      SavedJob[]
  createdAt      DateTime   @default(now())

  @@index([searchId])
  @@index([atsScore])
}

model SavedJob {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status    String    @default("saved")
  notes     String?
  appliedAt DateTime?
  createdAt DateTime  @default(now())

  @@unique([userId, jobId])
  @@index([userId, status])
}
